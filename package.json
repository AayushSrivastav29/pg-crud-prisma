{
  "name": "pg-crud-prisma",
  "version": "1.0.0",
  "description": "PostgreSQL CRUD operations with Prisma, TypeScript, Node.js, and Vue 3 + Ant Design",
  "main": "dist/server.js",
  "scripts": {
    "build": "vite build",
    "build:frontend": "vite build",
    "start": "node dist/server.js",
    "dev:server": "ts-node src/server.ts",
    "dev:client": "vite",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:cli": "ts-node src/index.ts",
    "preview": "vite preview",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "@prisma/client": "^5.14.0",
    "ant-design-vue": "^4.2.1",
    "axios": "^1.7.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "morgan": "^1.10.0",
    "vue": "^3.4.29",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.0.5",
    "concurrently": "^8.2.2",
    "prisma": "^5.14.0",
    "terser": "^5.48.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vue-tsc": "^2.0.21"
  }
}
